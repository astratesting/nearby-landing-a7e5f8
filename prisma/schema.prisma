generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  ELECTRONICS
  FURNITURE
  CLOTHING
  BABY_GEAR
  SPORTS
  BOOKS
  HOME_GARDEN
  TOYS
  VEHICLES
  OTHER
}

enum Condition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
}

enum ListingStatus {
  ACTIVE
  SOLD
  REMOVED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  neighborhood String    @default("")
  latitude     Float?
  longitude    Float?
  avatarUrl    String?
  bio          String?
  trustScore   Int       @default(0)
  isVerified   Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  listings      Listing[]  @relation("SellerListings")
  reviewsGiven  Review[]   @relation("Reviewer")
  reviewsReceived Review[] @relation("Reviewed")
  favorites     Favorite[]
}

model Listing {
  id           String        @id @default(cuid())
  title        String
  description  String
  price        Decimal       @db.Decimal(10, 2)
  category     Category
  condition    Condition     @default(GOOD)
  imageUrl     String?
  imageUrls    String[]
  neighborhood String
  latitude     Float?
  longitude    Float?
  sellerId     String
  seller       User          @relation("SellerListings", fields: [sellerId], references: [id])
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  reviews   Review[]
  favorites Favorite[]
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String
  reviewerId String
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewedId String
  reviewed   User     @relation("Reviewed", fields: [reviewedId], references: [id])
  listingId  String?
  listing    Listing? @relation(fields: [listingId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([reviewerId, reviewedId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}